# ── HMRC Application credentials ─────────────────────────────────────────────────
# Register your application at https://developer.service.hmrc.gov.uk/
HMRC_CLIENT_ID=your_client_id_here
HMRC_CLIENT_SECRET=your_client_secret_here

# ── HMRC API base URL ─────────────────────────────────────────────────────────────
# Sandbox (testing):
HMRC_BASE_URL=https://test-api.service.hmrc.gov.uk
# Production (uncomment when going live):
# HMRC_BASE_URL=https://api.service.hmrc.gov.uk

# ── OAuth callback URL ────────────────────────────────────────────────────────────
# Must match EXACTLY what is registered in your HMRC Developer Hub application.
# Local development:
REDIRECT_URI=http://localhost:8000/auth/callback
# Deployed (replace with your actual domain):
# REDIRECT_URI=https://your-app.vercel.app/auth/callback

# ── SQLite database path ──────────────────────────────────────────────────────────
# Relative to the project root.  For Vercel, use /tmp/hmrc_tokens.db
DB_PATH=hmrc_tokens.db

# ── Vendor / product identity (used in Gov-Vendor-* fraud prevention headers) ─────
# These should match your HMRC application registration name and version.
VENDOR_VERSION=PropertyLandlordApp=1.0.0
VENDOR_PRODUCT_NAME=Property%20Landlord%20MTD
VENDOR_LICENSE_IDS=property-landlord=00000000-0000-0000-0000-000000000001

# Gov-Vendor-Public-IP — the public IP of YOUR server.
#
# Option A (recommended for Vercel / any cloud without a static IP — FREE):
#   Leave VENDOR_PUBLIC_IP unset. The app calls https://api4.ipify.org at startup
#   to auto-detect the current outbound IP and caches it for the process lifetime.
#   On Vercel, each cold start gets a fresh IP — HMRC only requires a valid public
#   IP, not a permanently fixed one.
#
# Option B (if you have a static IP — e.g. Railway, Render Pro, or a VPS):
#   Set VENDOR_PUBLIC_IP to your static IP and skip the ipify lookup entirely.
#
# VENDOR_PUBLIC_IP=1.2.3.4

# Fallback if ipify is unreachable AND VENDOR_PUBLIC_IP is not set.
# RFC 5737 TEST-NET — accepted by HMRC's sandbox validator.
VENDOR_PUBLIC_IP_FALLBACK=198.51.100.2

# When the inbound request has no usable public IP (e.g. localhost in dev), use
# this for Gov-Client-Public-IP and Gov-Vendor-Forwarded `for=`.
FRAUD_CLIENT_PUBLIC_IP_FALLBACK=198.51.100.1

# ── CORS ──────────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins.  Use * for development only.
ALLOW_ORIGINS=*

# ── Xero Application credentials ─────────────────────────────────────────────────
# Register your application at https://developer.xero.com/myapps
# App type: Web App  |  Grant type: Authorization Code  |  Enable OpenID Connect
XERO_CLIENT_ID=your_xero_client_id_here
XERO_CLIENT_SECRET=your_xero_client_secret_here

# Must match exactly what is registered in your Xero Developer Portal app.
# Local development:
# XERO_REDIRECT_URI=http://localhost:8000/xero/callback
# Deployed:
XERO_REDIRECT_URI=https://hmrc-mtd-ap-is.vercel.app/xero/callback
