# ── HMRC Application credentials ─────────────────────────────────────────────────
# Register your application at https://developer.service.hmrc.gov.uk/
HMRC_CLIENT_ID=your_client_id_here
HMRC_CLIENT_SECRET=your_client_secret_here

# ── HMRC API base URL ─────────────────────────────────────────────────────────────
# Sandbox (testing):
HMRC_BASE_URL=https://test-api.service.hmrc.gov.uk
# Production (uncomment when going live):
# HMRC_BASE_URL=https://api.service.hmrc.gov.uk

# ── OAuth callback URL ────────────────────────────────────────────────────────────
# Must match EXACTLY what is registered in your HMRC Developer Hub application.
# Local development:
REDIRECT_URI=http://localhost:8000/auth/callback
# Deployed (replace with your actual domain):
# REDIRECT_URI=https://your-app.vercel.app/auth/callback

# ── SQLite database path ──────────────────────────────────────────────────────────
# Relative to the project root.  For Vercel, use /tmp/hmrc_tokens.db
DB_PATH=hmrc_tokens.db

# ── Vendor / product identity (used in Gov-Vendor-* fraud prevention headers) ─────
# These should match your HMRC application registration name and version.
VENDOR_VERSION=PropertyLandlordApp=1.0.0
VENDOR_PRODUCT_NAME=Property%20Landlord%20MTD
VENDOR_LICENSE_IDS=property-landlord=00000000-0000-0000-0000-000000000001
# Public IP of your server (Gov-Vendor-Public-IP header).
# On Vercel / serverless this is typically your egress IP.
VENDOR_PUBLIC_IP=198.51.100.2
# If VENDOR_PUBLIC_IP is unset or is private/loopback, this value is used instead.
VENDOR_PUBLIC_IP_FALLBACK=198.51.100.2
# When the inbound request has no usable public IP (e.g. localhost), use this for
# Gov-Client-Public-IP and Gov-Vendor-Forwarded `for=` (RFC 5737 TEST-NET; sandbox-safe).
FRAUD_CLIENT_PUBLIC_IP_FALLBACK=198.51.100.1

# ── CORS ──────────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins.  Use * for development only.
ALLOW_ORIGINS=*
